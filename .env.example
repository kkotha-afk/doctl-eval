# DigitalOcean Serverless Inference (OpenAI-compatible)
# Base URL is fixed per DO docs: https://docs.digitalocean.com/products/inference/how-to/use-serverless-inference/
SI_BASE_URL=https://inference.do-ai.run/v1
# Your DigitalOcean model access key (generate in the GradientAI Platform). DO NOT COMMIT.
SI_API_KEY=

# Eval runner concurrency (parallel inference requests). Configurable without rebuilding the container.
CONCURRENCY=8

# Optional GitHub token for higher rate limits during corpus ingestion (public API works without it).
GITHUB_TOKEN=
